SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,yourdomain.uz,www.yourdomain.uz
CSRF_TRUSTED_ORIGINS=https://yourdomain.uz,https://www.yourdomain.uz

# Database
# Option A — single connection string (Railway sets DATABASE_URL automatically):
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# Option B — separate vars (DB_HOST=localhost for local, db for Docker):
DB_ENGINE=django.db.backends.postgresql
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432
# Leave the DB vars empty to fall back to local SQLite.

# Docker (optional)
GUNICORN_WORKERS=3

EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# AI engine API keys — multiple keys for rotation (comma or space separated).
GEMINI_API_KEYS=key1,key2,key3
